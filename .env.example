# ============================================================
#  B2B Lead Generation AI Agent — Environment Configuration
#  Copy this file to `.env` and fill in your keys.
#  `.env` is gitignored and must never be committed.
# ============================================================

# ---- Required ----
APOLLO_API_KEY=your_apollo_key_here

# Google Places API (New) key — used to resolve verified location (city/state/
# address/geo), phone, website, business type & rating. Enable the
# "Places API (New)" in Google Cloud. Recommended; location enrichment is
# skipped if unset.
GOOGLE_PLACES_API_KEY=your_google_places_key_here

# Required when SEARCH_PROVIDER=google_cse (the default)
GOOGLE_CSE_API_KEY=your_google_cse_key_here
GOOGLE_CSE_ID=your_cse_id_here

# NewsAPI key (https://newsapi.org) — preferred source for news/expansion buying
# signals (exact publish dates + article URLs). Optional; if unset, news signals
# fall back to the configured SEARCH_PROVIDER below.
NEWSAPI_API_KEY=your_newsapi_key_here

# GST verification (optional) — confirms a company's GSTIN is active for the
# "GST verified & active" qualification point. GSTIN is extracted from the
# company's own website; this API confirms its status. Default URL targets a
# common GST-verify provider; override GST_API_URL for your provider.
# GST_API_KEY=your_gst_api_key_here
# GST_API_URL=https://appyflow.in/api/verifyGST

# ---- Search Provider (default: google_cse) ----
# Accepted values: google_cse | serpapi | brave
SEARCH_PROVIDER=google_cse

# Required only for the matching provider:
# SERPAPI_API_KEY=your_serpapi_key_here
# BRAVE_API_KEY=your_brave_key_here

# ---- Optional ----
MAX_CONCURRENT_BROWSERS=3
QUERIES_PER_RUN=20
OUTPUT_DIR=./leads
STORAGE_BACKEND=sqlite          # sqlite | json
GOOGLE_CSE_DAILY_LIMIT=100      # raise for paid Google CSE tiers

# ---- Proxy (optional) ----
# Newline-separated host:port:username:password entries.
# PROXY_LIST=proxy1.example.com:8080:user:pass

# ---- LLM Signal Scoring (optional, disabled by default) ----
# LLM_SIGNAL_SCORING=true
# LLM_API_KEY=sk-...            # sk-ant- -> Anthropic, sk- -> OpenAI
# LLM_MODEL=gpt-4o-mini
